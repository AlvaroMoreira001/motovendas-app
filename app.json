{
  "expo": {
    "name": "MotoVendas",
    "slug": "motovendas-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "android": {
      "package": "com.motovendas.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "O app precisa acessar suas fotos para você escolher uma imagem.",
          "cameraPermission": "O app precisa da câmera para você tirar uma foto."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "134a6392-6199-43cc-804e-37cbc836866c"
      }
    }
  }
}
